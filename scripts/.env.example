# Firebase Service Account (easier method: use file path)
# Get this from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=/Users/YOUR_USERNAME/Downloads/oscar-property-1cc52-firebase-adminsdk-fbsvc-0b5033c45d.json

# Alternative: Paste the entire JSON as a single line (complex, not recommended)
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'

# Firebase Storage Bucket (optional, uses default if not set)
FIREBASE_STORAGE_BUCKET='oscar-property-1cc52.firebasestorage.app'
